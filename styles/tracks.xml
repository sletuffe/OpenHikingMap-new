<!-- tracktype is only considered in 2 cases : 
grade1 = usable by car because paved
grade2 is most likely to be usable by normal cars, but that isn't certain, that could be added as a or.
grade5 = "unimproved track lacking hard materials" is supposed, in absence of smoothness, to not be usable by cars
-->
<Style name="tracks">
  <Rule>
    <Filter>[highway] = 'track'</Filter>
    &maxscale_zoom13;
    &minscale_zoom13;
    <LineSymbolizer stroke-linejoin="round" stroke="white" stroke-width="3" stroke-linecap="round" stroke-opacity="0.4"/><LineSymbolizer stroke-linejoin="round" stroke="#996600" stroke-width="1.5" stroke-dasharray="3,4" stroke-linecap="round"/>
  </Rule>      
  <Rule>
    &maxscale_zoom14; &minscale_zoom15;
    <Filter>[highway] = 'track' and ([surface] = 'asphalt' or [surface] = 'paved' or [surface] = 'concrete' or [surface] = 'paving_stones' or [smoothness] = 'excellent' or [smoothness] = 'good' or ([smoothness] = null and [tracktype] = 'grade1'))</Filter>
    <LineSymbolizer stroke="black" stroke-width="4.6" stroke-linecap="round" />
    <LineSymbolizer stroke="white" stroke-width="2.8" stroke-linecap="round" />
  </Rule>
  <Rule>
    &maxscale_zoom14; &minscale_zoom15;
    <Filter>[highway] = 'track' and ([smoothness] = 'horrible' or [smoothness] = 'very_horrible' or ([smoothness] = null and [tracktype] = 'grade5'))</Filter>
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="1" stroke-dasharray="4,4" stroke-opacity="0.65" />
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="-1" stroke-dasharray="4,4" stroke-opacity="0.65" />
  </Rule>
  <Rule>
    &maxscale_zoom14; &minscale_zoom15;
    <Filter>[highway] = 'track' and [smoothness] = 'very_bad'</Filter>
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="1" stroke-opacity="0.65" />
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="-1" stroke-dasharray="6,4" stroke-opacity="0.65" />
  </Rule>
  <Rule>
    &maxscale_zoom14; &minscale_zoom15;
    <Filter>[highway] = 'track' and ([smoothness] = 'intermediate' or [smoothness] = 'bad')</Filter>
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="1" stroke-opacity="0.65" />
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="-1" stroke-opacity="0.65" />
  </Rule>
  <Rule>
    &maxscale_zoom14; &minscale_zoom15;
    <Filter>[highway] = 'track' and not ([surface] = 'asphalt' or [surface] = 'paved' or [surface] = 'concrete' or [surface] = 'paving_stones' or [smoothness] = 'excellent' or [smoothness] = 'good' or [smoothness] = 'intermediate' or [smoothness] = 'bad' or [smoothness] = 'very_bad' or [smoothness] = 'horrible' or [smoothness] = 'very_horrible' or [tracktype] = 'grade1' or [tracktype] = 'grade5')</Filter>
    <LineSymbolizer stroke="#8B4513" stroke-width="1.1" offset="1" stroke-dasharray="5,5" stroke-opacity="0.65" />
    <LineSymbolizer stroke="#8B4513" stroke-width="1.1" offset="-1" stroke-dasharray="5,5" stroke-opacity="0.65" />
    <TextSymbolizer fontset-name="sans-condensed" size="11" fill="#8B4513" opacity="0.7" halo-fill="#FFFFFF66" halo-radius="1.5" placement="line" spacing="180">"?"</TextSymbolizer>
  </Rule>
  
  <Rule>
    &maxscale_zoom16; &minscale_zoom18;
    <Filter>[highway] = 'track' and ([surface] = 'asphalt' or [surface] = 'paved' or [surface] = 'concrete' or [surface] = 'paving_stones' or [smoothness] = 'excellent' or [smoothness] = 'good' or ([smoothness] = null and [tracktype] = 'grade1'))</Filter>
    <LineSymbolizer stroke="black" stroke-width="4.6" stroke-linecap="round" />
    <LineSymbolizer stroke="white" stroke-width="2.8" stroke-linecap="round" />
  </Rule>
  <Rule>
    &maxscale_zoom16; &minscale_zoom18;
    <Filter>[highway] = 'track' and ([smoothness] = 'horrible' or [smoothness] = 'very_horrible' or ([smoothness] = null and [tracktype] = 'grade5'))</Filter>
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="1.8" stroke-dasharray="4,4" stroke-opacity="0.65" />
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="-1.8" stroke-dasharray="4,4" stroke-opacity="0.65" />
  </Rule>
  <Rule>
    &maxscale_zoom16; &minscale_zoom18;
    <Filter>[highway] = 'track' and [smoothness] = 'very_bad'</Filter>
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="1.8" stroke-opacity="0.65" />
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="-1.8" stroke-dasharray="6,4" stroke-opacity="0.65" />
  </Rule>
  <Rule>
    &maxscale_zoom16; &minscale_zoom18;
    <Filter>[highway] = 'track' and ([smoothness] = 'intermediate' or [smoothness] = 'bad')</Filter>
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="1.8" stroke-opacity="0.65" />
    <LineSymbolizer stroke="#8B4513" stroke-width="1.2" offset="-1.8" stroke-opacity="0.65" />
  </Rule>
  <Rule>
    &maxscale_zoom16; &minscale_zoom18;
    <Filter>[highway] = 'track' and not ([surface] = 'asphalt' or [surface] = 'paved' or [surface] = 'concrete' or [surface] = 'paving_stones' or [smoothness] = 'excellent' or [smoothness] = 'good' or [smoothness] = 'intermediate' or [smoothness] = 'bad' or [smoothness] = 'very_bad' or [smoothness] = 'horrible' or [smoothness] = 'very_horrible' or [tracktype] = 'grade5')</Filter>
    <LineSymbolizer stroke="#8B4513" stroke-width="1.1" offset="1.8" stroke-dasharray="5,5" stroke-opacity="0.65" />
    <LineSymbolizer stroke="#8B4513" stroke-width="1.1" offset="-1.8" stroke-dasharray="5,5" stroke-opacity="0.65" />
    <TextSymbolizer fontset-name="sans-condensed" size="11" fill="#8B4513" opacity="0.7" halo-fill="#FFFFFF66" halo-radius="1.5" placement="line" spacing="180">"?"</TextSymbolizer>
  </Rule>  
</Style>
